{
  "//comment_1": "默认使用 RTP over UDP 主动推流；protocol 也可配置为 rtmp 或 webrtc。",
  "//comment_2": "RTMP 使用 rtmp_url，WebRTC 使用 webrtc_url，RTP 使用 server_ip/video_port/audio_port。",
  "video": {
    "source": "mipi_13855",
    "fallback_source": "usb_c270",
    "device": "/dev/video11",
    "fallback_device": "/dev/video21",
    "fallback_format": "MJPEG",
    "width": 1280,
    "height": 720,
    "fps": 30,
    "format": "NV12",
    "sensor_subdev": "/dev/v4l-subdev2",
    "sensor_exposure": 3000,
    "sensor_vblank": 78
  },
  "audio": {
    "device": "hw:1,0",
    "sample_rate": 48000,
    "channels": 1,
    "format": "S16_LE",
    "frame_ms": 20
  },
  "encoder": {
    "video_codec": "h264",
    "bitrate": 4000000,
    "gop": 30,
    "low_latency": true,
    "b_frames": 0
  },
  "stream": {
    "protocol": "rtp",
    "rtmp_url": "rtmp://{server_ip}:1935/live/stream",
    "webrtc_url": "http://{server_ip}:8889/live/stream/whip",
    "server_ip": "127.0.0.1",
    "video_port": 5004,
    "audio_port": 5006,
    "sdp_path": "test.sdp"
  },
  "debug": {
    "enable_perf_log": true,
    "enable_dump_frame": false
  }
}
