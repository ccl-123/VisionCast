{
  "//comment_1": "首选使用 webrtc 协议进行低延迟推流，其次支持 rtsp、rtmp 和 rtp 协议。可在 protocol 中配置。",
  "//comment_2": "WebRTC 使用 webrtc_url，RTSP 使用 rtsp_url/rtsp_transport，RTMP 使用 rtmp_url，RTP 使用 server_ip/video_port/audio_port。",
  "//comment_3": "运行脚本固定选择 video_profiles 中的摄像头：run_13855_camera.sh 使用 mipi_13855，run_usb_camera.sh 使用 usb_c270。",
  "video_profile": "mipi_13855",
  "video_profiles": {
    "mipi_13855": {
      "source": "mipi_13855",
      "fallback_source": "usb_c270",
      "device": "/dev/video11",
      "fallback_device": "/dev/video21",
      "fallback_format": "MJPEG",
      "width": 1920,
      "height": 1080,
      "fps": 30,
      "format": "NV12",
      "sensor_subdev": "/dev/v4l-subdev2",
      "crop_left": 0,
      "crop_top": 380,
      "crop_width": 4224,
      "crop_height": 2376,
      "sensor_exposure": 1928,
      "sensor_vblank": 78,
      "sensor_analogue_gain": 1536
    },
    "usb_c270": {
      "source": "usb_c270",
      "fallback_source": "",
      "device": "/dev/video21",
      "fallback_device": "",
      "fallback_format": "",
      "width": 1280,
      "height": 720,
      "fps": 30,
      "format": "MJPEG"
    }
  },
  "audio": {
    "device": "hw:1,0",
    "sample_rate": 48000,
    "capture_channels": 2,
    "channels": 2,
    "format": "S16_LE",
    "frame_ms": 20
  },
  "encoder": {
    "video_codec": "h264",
    "bitrate": 10000000,
    "gop": 30,
    "low_latency": true,
    "b_frames": 0
  },
  "stream": {
    "protocol": "webrtc",
    "rtmp_url": "rtmp://192.168.137.1:1936/live/stream",
    "webrtc_url": "http://192.168.137.1:8891/live/stream/whip",
    "rtsp_url": "rtsp://192.168.137.1:8554/live/stream",
    "rtsp_transport": "udp",
    "server_ip": "192.168.137.1",
    "video_port": 5004,
    "audio_port": 5006,
    "sdp_path": "test.sdp"
  },
  "debug": {
    "enable_perf_log": true,
    "enable_preview": false,
    "enable_dump_frame": false
  }
}
